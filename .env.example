# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# WCA API Configuration
WCA_API_BASE_URL=https://www.worldcubeassociation.org/api/v0

# WCA OAuth (register your app at https://www.worldcubeassociation.org/oauth/applications)
WCA_CLIENT_ID=your_wca_oauth_client_id
WCA_CLIENT_SECRET=your_wca_oauth_client_secret
WCA_REDIRECT_URI=http://localhost:5000/auth/wca/callback

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Flask session secret — use a long random string in production
SECRET_KEY=your_random_secret_key_here

# Database Configuration (Optional - for future local database support)
DATABASE_URL=

# Bot Settings
COMMAND_PREFIX=!wca
MAX_QUERY_RESULTS=50
